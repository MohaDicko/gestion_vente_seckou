{
  "name": "sekou-draperie-management",
  "version": "0.1.0",
  "packageManager": "npm@10.2.4",
  "private": true,
  "scripts": {
    "build": "turbo run build --filter=web",
    "build:web": "turbo run build --filter=web",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "npx playwright test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:seed": "npx tsx packages/database/prisma/seed.ts",
    "db:push": "npx prisma db push --schema=packages/database/prisma/schema.prisma"
  },
  "prisma": {
    "seed": "npx tsx packages/database/prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@playwright/test": "^1.58.2",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "turbo": "latest"
  },
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
